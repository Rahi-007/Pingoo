{
  "name": "pingoo",
  "version": "1.0.0",
  "description": "for Pingoo - Hybrid Messaging App",
  "keywords": [
    "Rahi",
    "Bisakto-Rahi",
    "pingoo",
    "messaging",
    "hybrid"
  ],
  "homepage": "https://github.com/Rahi-007/Pingoo#readme",
  "bugs": {
    "url": "https://github.com/Rahi-007/Pingoo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rahi-007/Pingoo.git"
  },
  "license": "MIT",
  "author": "Bisakto-Rahi",
  "directories": {
    "front": "frontend",
    "back": "backend",
    "doc": "docs"
  },
  "scripts": {
    "install:all": "npm install && npm install --prefix apps/frontend && npm install --prefix apps/backend",
    "frontend": "npm run dev --prefix apps/frontend",
    "backend": "npm run start:dev --prefix apps/backend",
    "build": "npm run build --prefix apps/frontend && npm run build --prefix apps/backend",
    "dev": "concurrently \"npm run dev --prefix apps/frontend\" \"npm run start:dev --prefix apps/backend\"",
    "format": "concurrently \"npm run format --prefix apps/backend\" \"npm run format --prefix apps/frontend\"",
    "clean": "rimraf node_modules apps/frontend/node_modules apps/backend/node_modules",
    "refresh:db": "npm run seed --prefix apps/backend",
    "sync:db": "npm run seed:sync --prefix apps/backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
